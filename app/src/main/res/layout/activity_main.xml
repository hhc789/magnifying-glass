<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingTop="48dp"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_floating_button"
            android:gravity="center"
            android:text="🔍"
            android:textSize="28sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/onboarding_title"
            android:textAppearance="?attr/textAppearanceHeadline5"
            android:textColor="@color/on_surface" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/onboarding_subtitle"
            android:textAppearance="?attr/textAppearanceBody2"
            android:textColor="@color/on_surface_variant" />
    </LinearLayout>

    <!-- Permission cards -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="24dp">

        <!-- Overlay permission card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_overlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="12dp"
            app:strokeColor="@color/on_surface_variant"
            app:strokeWidth="0.5dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/iv_overlay_status"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_magnify_off"
                    android:tint="@color/on_surface_variant"
                    android:contentDescription="@null" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/card_overlay_title"
                        android:textAppearance="?attr/textAppearanceSubtitle1"
                        android:textColor="@color/on_surface" />

                    <TextView
                        android:id="@+id/tv_overlay_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/card_overlay_desc"
                        android:textAppearance="?attr/textAppearanceBody2"
                        android:textColor="@color/on_surface_variant" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_overlay"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/card_overlay_action" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Screen capture permission card (needed for MediaProjection) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_capture"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="12dp"
            app:strokeColor="@color/on_surface_variant"
            app:strokeWidth="0.5dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/iv_capture_status"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_magnify_off"
                    android:tint="@color/on_surface_variant"
                    android:contentDescription="@null" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="屏幕截图权限"
                        android:textAppearance="?attr/textAppearanceSubtitle1"
                        android:textColor="@color/on_surface" />

                    <TextView
                        android:id="@+id/tv_capture_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="放大镜需要屏幕截图权限"
                        android:textAppearance="?attr/textAppearanceBody2"
                        android:textColor="@color/on_surface_variant" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_grant_capture"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="授予权限" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Accessibility service card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_accessibility"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="12dp"
            app:strokeColor="@color/on_surface_variant"
            app:strokeWidth="0.5dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/iv_accessibility_status"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_magnify_off"
                    android:tint="@color/on_surface_variant"
                    android:contentDescription="@null" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/card_accessibility_title"
                        android:textAppearance="?attr/textAppearanceSubtitle1"
                        android:textColor="@color/on_surface" />

                    <TextView
                        android:id="@+id/tv_accessibility_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/card_accessibility_guide"
                        android:textAppearance="?attr/textAppearanceBody2"
                        android:textColor="@color/on_surface_variant" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_accessibility"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/card_accessibility_action" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Unsupported device card (hidden by default) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_unsupported"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:visibility="gone"
            app:cardElevation="2dp"
            app:cardCornerRadius="12dp"
            app:strokeColor="@color/warning"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_magnify_off"
                    android:tint="@color/warning"
                    android:contentDescription="@null" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/card_unsupported_title"
                        android:textAppearance="?attr/textAppearanceSubtitle1"
                        android:textColor="@color/on_surface" />

                    <TextView
                        android:id="@+id/tv_unsupported_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/card_unsupported_fallback"
                        android:textAppearance="?attr/textAppearanceBody2"
                        android:textColor="@color/on_surface_variant" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_unsupported"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/card_unsupported_action"
                    android:textColor="@color/warning" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <!-- Status footer -->
    <TextView
        android:id="@+id/tv_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="16dp"
        android:text="@string/status_pending"
        android:textAppearance="?attr/textAppearanceBody2"
        android:textColor="@color/on_surface_variant" />
</LinearLayout>
